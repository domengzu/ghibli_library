<div class="mx-auto max-w-5xl flex gap-8 flex-col lg:flex-row">
  <div class="p-8">
    <%= render partial: "ghiblis/film", locals: { film: @film } %>
  </div>
  <div>
    <%= render partial: "comments/create_form", locals: {comment: @comment} %>
  </div>
  <div>
    <% @comments.each do |comment| %>
    <div class="mb-4 p-4 border rounded">
      <p class="text-gray-800"><%= comment.body %></p>
      <p class="text-sm text-gray-500 mt-2">
        Posted on <%= comment.created_at.strftime("%B %d, %Y at %I:%M %p") %>
      </p>
    </div>
    <% end %>
  </div>
</div>