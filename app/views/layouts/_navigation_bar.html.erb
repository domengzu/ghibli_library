<div class="navbar bg-base-100 shadow-sm px-4">
    <div class="navbar-start">
        <%= image_tag "hayao-miyazaki.png", alt: "Ghibli Library Icon", class: "size-14" %>
    </div>
    <div class="navbar-center">
        <%= link_to "Ghibli Library", root_path, class: "text-xl font-button font-semibold" %>
    </div>
    <div class="navbar-end">
        <label class="btn btn-ghost btn-circle swap swap-rotate" data-controller="theme" data-action="click->theme#toggle">
            <input type="checkbox" data-theme-target="checkbox" class="hidden" />
            <span class="swap-on">
                <%= icon "sun", library: "phosphor", variant: "bold", class: "size-8" %>
            </span>
            <span class="swap-off">
                <%= icon "moon", library: "phosphor", variant: "bold", class: "size-8" %>
            </span>
        </label>
    </div>
</div>