<div data-nav-height-target="nav" md:shadow-none class="navbar site-nav bg-mix md:px-4 sticky top-0 z-50 bg-base-100">
  <!-- Left side: Logo -->
  <div class="navbar-start">
    <%= image_tag "hayao-miyazaki.png", alt: "Ghibli Library Icon", class: "size-14" %>
  </div>

  <!---- Center: Site title/logo -->
  <div class="navbar-center">
    <%= link_to "Ghibli Library", root_path, class: "text-xl font-button font-semibold" %>
  </div>

  <!-- Right side: Sign in/up and theme toggle -->
  <div class="navbar-end gap-2 md:gap-4 drawer flex items-center justify-end">
    <div class="hidden md:flex gap-2 align-items-center">
      <% if user_signed_in? %>
      <%= link_to "Profile", edit_user_registration_path, class: "btn btn-ghost btn-sm transition" %>
      <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-ghost btn-sm transition" %>
      <% else %>
      <%= link_to "Sign in", new_user_session_path, class: "btn btn-success btn-outline btn-sm transition" %>
      <%= link_to "Sign up", new_user_registration_path, class: "btn btn-info btn-outline btn-sm transition" %>
      <% end %>
    </div>

    <!-- Theme Toggle -->
    <label class="btn btn-ghost btn-circle swap swap-rotate" data-controller="theme" data-action="click->theme#toggle">
      <input type="checkbox" data-theme-target="checkbox" class="hidden" />
      <span class="swap-on">
        <%= icon "sun", library: "phosphor", variant: "bold", class: "size-8" %>
      </span>
      <span class="swap-off">
        <%= icon "moon", library: "phosphor", variant: "bold", class: "size-8" %>
      </span>
    </label>

    <!-- Drawer -->
    <input id="my-drawer-1" type="checkbox" class="drawer-toggle" />
    <div class="drawer-content">
      <label for="my-drawer-1" class="drawer-button md:hidden inline">
        <%= icon "list", library: "phosphor", variant: "bold", class: "size-8" %>
      </label>
    </div>
    <div class="drawer-side">
      <label for="my-drawer-1" aria-label="close sidebar" class="drawer-overlay"></label>
      <ul class="menu bg-base-200 min-h-full w-80 p-4">
        <!-- Sidebar content here -->
        <% if user_signed_in? %>
        <%= link_to "Profile", edit_user_registration_path, class: "btn btn-ghost btn-sm transition" %>

        <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-ghost btn-sm transition" %>
        <% else %>
        <%= link_to "Sign in", new_user_session_path, class: "btn btn-success btn-outline btn-sm transition" %>
        <%= link_to "Sign up", new_user_registration_path, class: "btn btn-info btn-outline btn-sm transition" %>
        <% end %>
      </ul>
    </div>
  </div>
</div>