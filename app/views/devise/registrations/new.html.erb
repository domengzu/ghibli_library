<%= render "devise/shared/error_messages", resource: resource %>

<div class="flex align-center justify-center items-center font-button min-h-[calc(100vh-100px)]">
  <div class="flex flex-col items-center justify-center border-2 border-gray-200 p-10 rounded-lg shadow-xl gap-3">
    <div class="w-full mb-5">
      <h2 class="text-start text-2xl font-bold">Sign up ! <%= image_tag("smiling-capybara-with-three-hearts.png", class: "size-9 inline")  %></h2>
      <h2 class="text-start text-xl font-bold w-full text-primary">Create your account here</h2>
    </div>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <div class="mb-3">
      <p class="text-sm"><%= f.label :email %></p>
      <%= f.email_field :email,
        autofocus: true,
        autocomplete: "email",
        inputmode: "email",
        autocapitalize: "none",
        spellcheck: false,
        required: true,
        placeholder: "you@example.com",
        class: "w-full border border-gray-300 p-2 rounded-sm text-sm transition focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
      %>
    </div>

    <div class="mb-3">
      <p class="text-sm"><%= f.label :password %></p>
      <% if @minimum_password_length %>
      <p class="text-xs text-red-500 italic p-0 m-0"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
      <%= f.password_field :password, 
      autocomplete: "new-password",
      required: true,
      placeholder: "Enter your password",
      class: "w-full border border-gray-300 p-2 rounded-sm text-sm transition focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" %>
    </div>

    <div class="mb-3">
      <p class="text-sm"><%= f.label :password_confirmation %></p>
      <%= f.password_field :password_confirmation, 
      autocomplete: "new-password",
      required: true,
      placeholder: "Confirm your password",
      class: "w-full border border-gray-300 p-2 rounded-sm text-sm transition focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" %>
    </div>


    <div class="actions">
      <%= f.submit "Sign up", class: "btn btn-success btn-sm w-full" %>
    </div>
    <% end %>

    <%= render "devise/shared/links" %>

  </div>
</div>